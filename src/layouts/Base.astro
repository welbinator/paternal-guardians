---
import "../styles/pgi.css";

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;
const siteTitle = "Paternal Guardians of Iowa";
const fullTitle = title ? `${title} – ${siteTitle}` : `${siteTitle} – A network of support & resource center for Iowa Fathers`;
const siteDescription = description || "A network of support & resource center for Iowa Fathers";
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<meta name="description" content={siteDescription} />
		<link rel="icon" href="/images/Parental-Guardians-Of-Iowa-logo.png" />
	</head>
	<body>
		<header class="site-header" id="header">
			<div class="header-inner">
				<a href="/" class="brand">
					<img
						src="/images/Parental-Guardians-Of-Iowa-logo.png"
						alt="Paternal Guardians of Iowa"
						class="brand-logo"
					/>
					<span class="brand-text">
						<span class="brand-name">Paternal Guardians of Iowa</span>
						<span class="brand-tagline">A network of support &amp; resource center for Iowa Fathers</span>
					</span>
				</a>
				<nav class="main-nav">
					<a href="/" class={path === "/" ? "active" : ""}>HOME</a>
					<a href="/contact" class={path.startsWith("/contact") ? "active" : ""}>CONTACT</a>
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<a href="#header" class="back-to-top" aria-label="Back to top">↑</a>
			<nav class="footer-nav">
				<a href="/">HOME</a>
				<a href="/contact">CONTACT</a>
			</nav>
			<p class="footer-copy">
				© <a href="/">Paternal Guardians of Iowa</a> {new Date().getFullYear()}
			</p>
			<p class="footer-credit">
				Proudly built and hosted by
				<a href="https://cedarrapidswebdesign.com/" target="_blank" rel="noopener">Cedar Rapids Web Design</a>
			</p>
		</footer>
	</body>
</html>
