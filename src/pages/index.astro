---
import Base from "../layouts/Base.astro";
import { getEmDashCollection } from "emdash";

type EmDashImage = {
	meta?: { storageKey?: string };
} | null;

const { entries } = await getEmDashCollection("gallery", {
	status: "published",
	orderBy: { sort_order: "asc" },
	limit: 100,
});

const slides = entries
	.map((entry) => {
		const img = entry.data.photo as EmDashImage;
		const storageKey = img?.meta?.storageKey;
		if (!storageKey) return null;
		return {
			src: `/_emdash/api/media/file/${storageKey}`,
			alt: (entry.data.alt as string) ?? "",
		};
	})
	.filter((s): s is { src: string; alt: string } => s !== null);
---

<Base>
	<section class="slider">
		<div class="slider-inner">
			<div class="slides">
				{
					slides.map((slide, i) => (
						<div class={`slide${i === 0 ? " active" : ""}`} data-slide={i}>
							<img src={slide.src} alt={slide.alt} loading={i === 0 ? "eager" : "lazy"} />
						</div>
					))
				}
			</div>
			<button class="slider-btn prev" aria-label="Previous slide">&laquo;</button>
			<button class="slider-btn next" aria-label="Next slide">&raquo;</button>
			<div class="slider-dots" id="slider-dots"></div>
		</div>
	</section>

</Base>

<script>
	// Slider
	const slides = Array.from(document.querySelectorAll<HTMLElement>(".slide"));
	const dotsWrap = document.getElementById("slider-dots");
	let current = 0;

	function show(i: number) {
		current = (i + slides.length) % slides.length;
		slides.forEach((s, idx) => s.classList.toggle("active", idx === current));
		if (dotsWrap) {
			Array.from(dotsWrap.children).forEach((d, idx) =>
				d.classList.toggle("active", idx === current),
			);
		}
	}

	if (dotsWrap) {
		slides.forEach((_, i) => {
			const dot = document.createElement("button");
			dot.className = "dot" + (i === 0 ? " active" : "");
			dot.setAttribute("aria-label", `Go to slide ${i + 1}`);
			dot.addEventListener("click", () => show(i));
			dotsWrap.appendChild(dot);
		});
	}

	document.querySelector(".slider-btn.prev")?.addEventListener("click", () => show(current - 1));
	document.querySelector(".slider-btn.next")?.addEventListener("click", () => show(current + 1));

	let timer = setInterval(() => show(current + 1), 6000);
	const slider = document.querySelector(".slider");
	slider?.addEventListener("mouseenter", () => clearInterval(timer));
	slider?.addEventListener("mouseleave", () => {
		timer = setInterval(() => show(current + 1), 6000);
	});
</script>
