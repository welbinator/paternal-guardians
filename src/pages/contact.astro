---
import Base from "../layouts/Base.astro";

// Static contact page. The form is cosmetic — it shows a confirmation
// client-side but does not deliver mail (matches the prior behavior).
// To make it functional later, sign up for Web3Forms (free) and set the
// access key below, or swap the <form> action to Formspree.
const WEB3FORMS_KEY = ""; // <-- paste a Web3Forms access key to enable real delivery
const heading = "Contact";
const intro = "";
---

<Base title="Contact" description="Get in touch with Paternal Guardians of Iowa.">
	<div class="page">
		<h1>{heading}</h1>
		{intro && <p class="page-intro">{intro}</p>}

		<p class="form-note success" id="form-success" hidden>
			Thank you for reaching out. We'll get back to you as soon as we can.
		</p>

		<form
			class="contact-form"
			id="contact-form"
			method="POST"
			action={WEB3FORMS_KEY ? "https://api.web3forms.com/submit" : undefined}
		>
			{WEB3FORMS_KEY && <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />}
			<label>
				Name
				<input type="text" name="name" required />
			</label>
			<label>
				Phone
				<input type="tel" name="phone" />
			</label>
			<label>
				Email
				<input type="email" name="email" required />
			</label>
			<label>
				Subject
				<input type="text" name="subject" required />
			</label>
			<label>
				Message
				<textarea name="message" required></textarea>
			</label>
			<div>
				<button type="submit" class="btn">Submit</button>
			</div>
		</form>
	</div>
</Base>

<script>
	// If no real delivery backend is configured, intercept the submit and just
	// show the confirmation message (cosmetic form — same as the old behavior).
	const form = document.getElementById("contact-form") as HTMLFormElement | null;
	const success = document.getElementById("form-success");
	if (form && !form.getAttribute("action")) {
		form.addEventListener("submit", (e) => {
			e.preventDefault();
			form.reset();
			if (success) {
				success.hidden = false;
				success.scrollIntoView({ behavior: "smooth", block: "center" });
			}
		});
	}
</script>
